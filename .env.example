# Copy to .env.local and fill in. Never commit .env.local.

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="run: openssl rand -base64 32"

# Google OAuth (from console.cloud.google.com \u2192 JulzOps project \u2192 Credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Database \u2014 Phase 2 will set this to a Neon connection string
DATABASE_URL="postgresql://user:pass@localhost:5432/julzops?schema=public"

# Anthropic Admin API key (sk-ant-admin-...) for the hourly Cost API pull.
# Provision at platform.claude.com \u2192 Settings \u2192 Admin keys (requires Organization
# account, not individual). Used by /api/jobs/reconcile-usage.
ANTHROPIC_ADMIN_API_KEY=""

# Anthropic standard API key \u2014 reserved for any JulzOps-initiated Claude calls
# (retro generation, etc). Not required for the cost pull.
ANTHROPIC_API_KEY=""

# Bearer token shared between the hourly GHA workflow and the reconcile-usage
# route. Also used by the legacy sync.py \u2192 /api/ingest/cost webhook.
# Generate: openssl rand -base64 32
CRON_SECRET=""

# Legacy push-based cost ingest secret (being retired \u2014 see plan file
# yes-and-i-have-resilient-meerkat.md). Still referenced by /api/ingest/cost
# until workers stop POSTing.
JULZOPS_INGEST_SECRET=""

# Claude cost guard \u2014 hard abort per-run limit for JulzOps' own API calls
MAX_COST_PER_RUN_USD="1.00"

# Retro engine \u2014 disabled until threshold met (30 events OR 3 projects)
RETRO_ENABLED="false"
RETRO_MODEL="claude-opus-4-7"

# Event retention
RETENTION_DAYS="90"
