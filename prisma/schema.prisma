// JulzOps data model. Lives here in Phase 1 as types-only; no migrations run
// until Phase 2 provisions Neon.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id                   String   @id @default(cuid())
  slug                 String   @unique
  name                 String
  description          String?
  repoUrl              String?
  color                String?
  // Maps this Project to an Anthropic API workspace (wrkspc_...). Populated
  // manually once per project so we can attribute per-workspace Cost API rows
  // back to the right card on the dashboard. Null = no API usage tracked.
  anthropicWorkspaceId String?  @unique
  createdAt            DateTime @default(now())

  events      Event[]
  costSamples CostSample[]
}

model Event {
  id         String    @id @default(cuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source     String
  kind       String
  status     String
  title      String
  url        String?
  metadata   Json?
  startedAt  DateTime
  endedAt    DateTime?
  durationMs Int?
  createdAt  DateTime  @default(now())

  @@index([projectId, startedAt])
  @@index([source, kind])
  @@index([status, startedAt])
}

model CostSample {
  id           String   @id @default(cuid())
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  source       String
  model        String
  inputTokens  Int
  outputTokens Int
  cacheReadTokens   Int @default(0)
  cacheWriteTokens  Int @default(0)
  costUsd      Decimal  @db.Decimal(10, 6)
  sampledAt    DateTime
  createdAt    DateTime @default(now())

  @@index([projectId, sampledAt])
  @@index([source, model, sampledAt])
}

model Retro {
  id          String   @id @default(cuid())
  weekStart   DateTime @unique
  markdown    String   @db.Text
  highlights  Json?
  generatedAt DateTime @default(now())
}

// Per-day, per-workspace, per-description cost snapshot pulled from the
// Anthropic Cost API (/v1/organizations/cost_report). The hourly cron upserts
// today's row on every pull (costDate is a DATE, not a timestamp, so multiple
// pulls on the same UTC day collapse to one row per workspace+description).
// Past days become immutable ~5 min after UTC rollover (Anthropic data
// freshness window). description is the model+token-type label Anthropic
// returns, e.g. "claude-opus-4-6 input tokens (standard)".
//
// workspaceId is non-null: the Cost API returns null for default-workspace
// rows, but we coerce those to the sentinel string "default" at write time so
// the composite primary key deduplicates correctly. (Postgres treats NULL as
// distinct in unique constraints by default, which would otherwise cause
// hourly re-inserts instead of upserts on the default-workspace row.)
model AnthropicCost {
  costDate    DateTime @db.Date
  workspaceId String   // "default" sentinel for null Anthropic workspace_id
  description String
  costUsd     Decimal  @db.Decimal(10, 6)
  pulledAt    DateTime @default(now())

  @@id([costDate, workspaceId, description])
  @@index([costDate])
  @@index([workspaceId, costDate])
}
